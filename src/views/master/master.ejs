<%- include('../partials/head') %>
<%- include('../partials/header') %>

<div class="page-title-bar mt-25 mb-15">
    <div class="fs-18 fw-b fc-1">MAESTRO <span class="fw-n fst-i"><%= branch.branch.toUpperCase() %></span></div>
    <div class="action-bar">
        <div class="action-btn" id="openFilters">
            <i class="fa-solid fa-filter"></i>
            <span>Filtros</span>
        </div>
        <div class="action-btn filter-clear-btn not-visible" id="clearFiltersBtn">
            <i class="fa-solid fa-filter-circle-xmark"></i>
        </div>
        <div class="action-btn" id="create">
            <i class="fa-solid fa-plus"></i>
            <span>Crear</span>
        </div>
        <div class="action-btn" id="upload">
            <i class="fa-solid fa-upload"></i>
            <span>Subir</span>
        </div>
        <div class="action-btn" id="download">
            <i class="fa-solid fa-download"></i>
            <span>Descargar</span>
        </div>
    </div>
</div>

<!--- filter drawer --->
<div class="filter-drawer-overlay" id="filterDrawerOverlay"></div>
<div class="filter-drawer" id="filterDrawer">
    <div class="filter-drawer-header">
        <span class="filter-drawer-title">Filtros</span>
        <div class="filter-drawer-close" id="filterDrawerClose">
            <i class="fa-solid fa-xmark"></i>
        </div>
    </div>
    <div class="filter-drawer-body">
        <div class="filter-drawer-field">
            <label class="filter-drawer-label">Proveedor</label>
            <input type="text" class="filter-drawer-input" id="supplier" placeholder="Buscar por proveedor...">
        </div>
        <div class="filter-drawer-field">
            <label class="filter-drawer-label">Item</label>
            <input type="text" class="filter-drawer-input" id="item" placeholder="Buscar por item...">
        </div>
        <div class="filter-drawer-field">
            <label class="filter-drawer-label">Descripción</label>
            <input type="text" class="filter-drawer-input" id="description" placeholder="Buscar por descripción...">
        </div>
        <div class="filter-drawer-field">
            <label class="filter-drawer-checkbox-group">
                <input type="checkbox" id="volumeFilter" class="filter-drawer-checkbox">
                <span>Items sin volumen</span>
            </label>
            <label class="filter-drawer-checkbox-group">
                <input type="checkbox" id="weightFilter" class="filter-drawer-checkbox">
                <span>Items sin peso</span>
            </label>
        </div>
    </div>
    <div class="filter-drawer-footer">
        <button class="filter-drawer-btn filter-drawer-btn-apply" id="applyFilters">Aplicar</button>
        <button class="filter-drawer-btn filter-drawer-btn-clear" id="clearFilters">Limpiar</button>
    </div>
</div>

<!--- table --->
<div class="div-table max-h-550" id="table">

    <!-- table tooltip -->
    <table>
        <thead>
            <tr>
                <th class="th pad-3-0 w-170">Proveedor</th>
                <th class="th pad-3-0 w-150">Item</th>
                <th class="th pad-3-0 w-300">Descripción</th>
                <th class="th pad-3-0 w-90">UM</th>
                <th class="th pad-3-0 w-70">UM por caja</th>
                <th class="th pad-3-0 w-90">Peso (kg)</th>
                <th class="th pad-3-0 w-70">Volumen (m3)</th>
                <th class="th pad-3-0 w-90">FOB / UM</th>
                <th class="th pad-3-0 w-90">FOB / U</th>
                <th class="th pad-3-0 w-90">Moneda</th>                
                <th class="th pad-3-0 w-120">Costo estimado por unidad</th>
                <th class="th pad-3-0 w-120">Precio de lista (ARS)</th>
                <th class="th pad-3-0 w-120">Margen %</th>
            </tr>
        </thead>

        <tbody id="body"></tbody>
        
    </table>
</div>

<!----------POPUPS---------->
<%- include('../partials/resultsPopups') %>
<%- include('./masterCEIPP') %>
<%- include('../partials/confirmPopup') %>
<%- include('./masterFAPP') %>

<!----------LOADER---------->
<div class="loader ld-std" id="loader">
    <div class="ld-content ld-main top-45p"></div>
</div>

<!----------SCRIPTS---------->
<script type="module" src="/js/master/master.js"></script>

