<%- include('../partials/head') %>
<%- include('../partials/header') %>

<div class="page-title-bar mt-25 mb-15">
    <div class="fs-18 fw-b fc-1">LISTAS DE PRECIOS <span class="fw-n fst-i"><%= branch.branch.toUpperCase() %></span></div>
    <div class="action-bar">
        <div class="action-btn" id="openFilters">
            <i class="fa-solid fa-filter"></i>
            <span>Filtros</span>
        </div>
        <div class="action-btn filter-clear-btn not-visible" id="clearFiltersBtn">
            <i class="fa-solid fa-filter-circle-xmark"></i>
        </div>
        <div class="action-btn" id="printExcel">
            <i class="fa-solid fa-file-excel"></i>
            <span>Excel</span>
        </div>
        <div class="action-btn" id="printPdf">
            <i class="fa-solid fa-file-pdf"></i>
            <span>PDF</span>
        </div>
        <div class="action-btn" id="printErp">
            <i class="fa-solid fa-print"></i>
            <span>ERP</span>
        </div>
        <div class="action-btn" id="download">
            <i class="fa-solid fa-download"></i>
            <span>Descargar</span>
        </div>
    </div>
</div>

<!--- filter drawer --->
<div class="filter-drawer-overlay" id="filterDrawerOverlay"></div>
<div class="filter-drawer" id="filterDrawer">
    <div class="filter-drawer-header">
        <span class="filter-drawer-title">Filtros</span>
        <div class="filter-drawer-close" id="filterDrawerClose">
            <i class="fa-solid fa-xmark"></i>
        </div>
    </div>
    <div class="filter-drawer-body">
        <div class="filter-drawer-field">
            <label class="filter-drawer-label">Lista</label>
            <input type="text" class="filter-drawer-input" id="listName" placeholder="Buscar por lista...">
        </div>
        <div class="filter-drawer-field">
            <label class="filter-drawer-label">Categoría</label>
            <input type="text" class="filter-drawer-input" id="category" placeholder="Buscar por categoría...">
        </div>
        <div class="filter-drawer-field">
            <label class="filter-drawer-label">Proveedor</label>
            <input type="text" class="filter-drawer-input" id="supplier" placeholder="Buscar por proveedor...">
        </div>
        <div class="filter-drawer-field">
            <label class="filter-drawer-label">Item</label>
            <input type="text" class="filter-drawer-input" id="item" placeholder="Buscar en ERP, proveedor o lista...">
        </div>
        <div class="filter-drawer-field">
            <label class="filter-drawer-label">Descripción</label>
            <input type="text" class="filter-drawer-input" id="description" placeholder="Buscar por descripción...">
        </div>
    </div>
    <div class="filter-drawer-footer">
        <button class="filter-drawer-btn filter-drawer-btn-apply" id="applyFilters">Aplicar</button>
        <button class="filter-drawer-btn filter-drawer-btn-clear" id="clearFilters">Limpiar</button>
    </div>
</div>

<!--- table --->
<div class="div-table max-h-550" id="table">

    <!-- table tooltip -->
    <div class="t-tooltip" id="eippInfo">Editar</div>    
    <div class="t-tooltip" id="dippInfo">Eliminar</div>

    <table>
        <thead>
            <tr>
                <th class="th pad-3-0 w-120">Lista</th>
                <th class="th pad-3-0 w-300">Categoría</th>
                <th class="th pad-3-0 w-150">Proveedor</th>
                <th class="th pad-3-0 w-120">Item ERP</th>
                <th class="th pad-3-0 w-120">Item Proveedor</th>
                <th class="th pad-3-0 w-120">Item PDF</th>
                <th class="th pad-3-0 w-300">Descripción</th>
                <th class="th pad-3-0 w-120">Unidades / <br>Caja</th>
                <th class="th pad-3-0 w-120">Precio Dist. <br>(+ IVA)</th>
                <th class="th pad-3-0 w-120">Precio CF <br>(+ IVA)</th>
                <th class="th pad-3-0 w-120">Precio ML <br>(+ IVA)</th>
                
                <th class="th pad-3-0 w-50 pointer" id="eippIcon"><i class="fa-regular fa-pen-to-square"></i></th>                
                <th class="th pad-3-0 w-50 pointer" id="dippIcon"><i class="fa-regular fa-trash-can"></i></th>
            </tr>
        </thead>

        <tbody id="body"></tbody>
        
    </table>
</div>

<!----------POPUPS---------->
<%- include('./pricesListsSPPP') %>
<%- include('../partials/resultsPopups') %>
<%- include('../partials/confirmPopup') %>

<!----------LOADER---------->
<div class="loader ld-std" id="loader">
    <div class="ld-content ld-main top-45p"></div>
</div>

<!----------SCRIPTS---------->
<script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>
<script type="module" src="/js/pricesLists/pricesLists.js"></script>


